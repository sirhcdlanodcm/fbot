# Copy to .env and fill in real values. Never commit .env.

DISCORD_TOKEN=your-discord-bot-token
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MAX_TOKENS=2000
CONVERSATION_HISTORY_SIZE=10
OBJECTIVE_INJECTION_PROBABILITY=0.4
REACTION_PROBABILITY=0.1

# Optional: override current league champion without rebuilding the image.
# Must match a row in config/league_status.py LEAGUE_MEMBERS — any one of:
#   roster display name (case-insensitive)
#   Discord username = part of "key" before # (e.g. user from user#0)
#   full key (user#0)
#   numeric Discord user ID (snowflake)
#   Discord mention form <@id> or <@!id>
# LEAGUE_CHAMPION=

# Optional OpenAI instead of Gemini:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o
